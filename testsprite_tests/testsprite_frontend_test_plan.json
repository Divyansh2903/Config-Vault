[
  {
    "id": "TC001",
    "title": "Successful login redirects to dashboard",
    "description": "Verifies that a user can sign in with valid email/password and is redirected to the dashboard.",
    "category": "User Login",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Sign in\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the sign in button to submit"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/dashboard\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Dashboard\" is visible"
      }
    ]
  },
